 pipeline {
    agent any

    environment {
        REGISTRY      = "002191735381.dkr.ecr.eu-north-1.amazonaws.com"
        BACKEND_REPO  = "${REGISTRY}/backend"
        FRONTEND_REPO = "${REGISTRY}/frontend"
        AWS_REGION    = "eu-north-1"
        EC2_HOST      = "ubuntu@dev.tippu.dpdns.org"
        SLACK_CHANNEL = "#all-relationsync"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                slackSend(channel: "${SLACK_CHANNEL}", color: "#439FE0",
                    message: "🔧 *Dev pipeline started* — `${env.JOB_NAME}` #${env.BUILD_NUMBER}\nCommit: `${GIT_COMMIT}`")
            }
        }

        stage('Branch Guard') {
            steps {
                script {
                    if (!env.GIT_BRANCH?.endsWith('develop')) {
                        slackSend(channel: "${SLACK_CHANNEL}", color: "warning",
                            message: "⏭️ *Dev pipeline skipped* — push was to `${env.GIT_BRANCH}`, not `develop`")
                        currentBuild.result = 'NOT_BUILT'
                        error("Not the develop branch — skipping dev pipeline.")
                    }
                }
            }
        }

        stage('Build Dev Images') {
            steps {
                sh '''
                    echo "Cleaning old build cache..."
                    docker builder prune -af || true

                    echo "Removing old dev images..."
                    docker rmi -f ${BACKEND_REPO}:dev-${GIT_COMMIT} || true
                    docker rmi -f ${FRONTEND_REPO}:dev-${GIT_COMMIT} || true

                    echo "Building backend..."
                    docker build --pull --no-cache \
                        -f backend/Dockerfile.dev \
                        -t ${BACKEND_REPO}:dev-${GIT_COMMIT} \
                        ./backend

                    echo "Building frontend..."
                    docker build --pull --no-cache \
                        -f frontend/Dockerfile.dev \
                        -t ${FRONTEND_REPO}:dev-${GIT_COMMIT} \
                        ./frontend
                '''
                slackSend(channel: "${SLACK_CHANNEL}", color: "#439FE0",
                    message: "🛠️ *Dev images built* — backend + frontend, commit `${GIT_COMMIT}`")
            }
        }

        stage('Trivy Scan') {
            steps {
                sh """
                    trivy image --ignore-unfixed --severity HIGH,CRITICAL --exit-code 0 ${BACKEND_REPO}:dev-${GIT_COMMIT}
                """
                sh """
                    trivy image --ignore-unfixed --severity HIGH,CRITICAL --exit-code 0 ${FRONTEND_REPO}:dev-${GIT_COMMIT}
                """
                slackSend(channel: "${SLACK_CHANNEL}", color: "#439FE0",
                    message: "🔍 *Trivy scan complete* — dev images scanned (non-blocking), check console for findings")
            }
        }

        stage('Push to ECR') {
            steps {
                sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${REGISTRY}"
                sh "docker tag ${BACKEND_REPO}:dev-${GIT_COMMIT} ${BACKEND_REPO}:dev-latest"
                sh "docker tag ${FRONTEND_REPO}:dev-${GIT_COMMIT} ${FRONTEND_REPO}:dev-latest"
                sh "docker push ${BACKEND_REPO}:dev-${GIT_COMMIT}"
                sh "docker push ${BACKEND_REPO}:dev-latest"
                sh "docker push ${FRONTEND_REPO}:dev-${GIT_COMMIT}"
                sh "docker push ${FRONTEND_REPO}:dev-latest"
                slackSend(channel: "${SLACK_CHANNEL}", color: "#439FE0",
                    message: "📦 *Images pushed to ECR* — `dev-${GIT_COMMIT}` and `dev-latest`")
            }
        }

        stage('Deploy Dev to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_HOST} '
                            aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${REGISTRY} &&
                            cd ~/relationsync/devops-flow &&
                            docker compose -f docker-compose.ec2.dev.yml pull backend-dev frontend-dev &&
                            docker compose -f docker-compose.ec2.dev.yml up -d backend-dev frontend-dev
                        '
                    """
                }
            }
        }
    }

    post {
        success {
            slackSend(channel: "${SLACK_CHANNEL}", color: "good",
                message: "✅ *Dev deployed* — `${env.JOB_NAME}` #${env.BUILD_NUMBER}\n<http://dev.tippu.dpdns.org|View site> | <${env.BUILD_URL}|View build>")
        }
        failure {
            slackSend(channel: "${SLACK_CHANNEL}", color: "danger",
                message: "❌ *Dev pipeline failed* — `${env.JOB_NAME}` #${env.BUILD_NUMBER}\n<${env.BUILD_URL}console|View logs>")
        }
    }
}